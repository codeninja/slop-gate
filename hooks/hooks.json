{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Recording task intent"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking planned action for intent drift"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking tool result for intent drift"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking tool failure for intent drift"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking completed tool batch for intent drift"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking task creation for intent drift"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking task completion for intent drift"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking subagent response for intent drift"
          },
          {
            "type": "prompt",
            "prompt": "Slop Gate semantic subagent-stop condition. Return {\"ok\": true} if stop_hook_active is true or if the final message is not making a completion, validation, readiness, or user-as-tester claim. Return {\"ok\": false, \"reason\": \"...\"} only when that claim lacks concrete evidence in the final message, such as commands, tests, tool results, inspected files, or an explicit blocker. Hook event JSON: $ARGUMENTS",
            "timeout": 30,
            "statusMessage": "Semantically judging subagent stop"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/slop-gate-hook",
            "timeout": 5,
            "statusMessage": "Checking response for intent drift"
          },
          {
            "type": "prompt",
            "prompt": "Slop Gate semantic stop condition. Return {\"ok\": true} if stop_hook_active is true or if the final message is not making a completion, validation, readiness, or user-as-tester claim. Return {\"ok\": false, \"reason\": \"...\"} only when that claim lacks concrete evidence in the final message, such as commands, tests, tool results, inspected files, or an explicit blocker. Hook event JSON: $ARGUMENTS",
            "timeout": 30,
            "statusMessage": "Semantically judging stop"
          }
        ]
      }
    ]
  }
}
