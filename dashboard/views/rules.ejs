<%- include('partials/head', { title }) %>
<%- include('partials/nav', { currentPage }) %>

<h1 class="page-title">Rules</h1>
<p class="lede">Edit drift patterns as Markdown. Save writes to <code style="font-family: var(--font-mono); font-size: 0.9em;">patterns/drift-patterns.md</code> in the repo.</p>

<section class="panel" aria-labelledby="rules-editor-heading">
  <div class="panel-header">
    <h2 id="rules-editor-heading">Pattern definitions</h2>
  </div>
  <div class="panel-body">
    <form action="/rules" method="POST">
      <label class="field-label" for="patternContent">patterns/drift-patterns.md</label>
      <textarea id="patternContent" class="input rules-editor" name="patternContent" spellcheck="false"><%= patternContent %></textarea>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save patterns</button>
        <a class="btn btn-ghost" href="/">Back to evaluate</a>
      </div>
    </form>
    <p class="save-hint">After saving, reload Evaluate to refresh the scenario list.</p>
  </div>
</section>

<%- include('partials/footer') %>
