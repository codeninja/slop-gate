<%- include('partials/head', { title }) %>
<%- include('partials/nav', { currentPage }) %>

<h1 class="page-title">Drift Rules &amp; Patterns</h1>
<p class="lede">
  Define and maintain heuristics for LLM drift detection. Edits made below will save directly to <code style="font-family: var(--font-mono); font-size: 0.9em; background: hsl(var(--surface-raised) / 0.5); padding: 0.15rem 0.35rem; border-radius: 4px; color: hsl(var(--accent));">patterns/drift-patterns.md</code> in the repository.
</p>

<div class="rules-editor-wrapper">
  
  <!-- Left Side: Interactive Markdown Editor Panel -->
  <section class="panel" style="flex-grow: 1;">
    <div class="panel-header">
      <h2>
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="margin-right: 4px; color: hsl(var(--accent));">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        patterns/drift-patterns.md
      </h2>
    </div>
    <div class="panel-body">
      <form action="/rules" method="POST">
        <label class="field-label" for="patternContent">Markdown Definition Source</label>
        <textarea 
          id="patternContent" 
          class="input rules-editor" 
          name="patternContent" 
          spellcheck="false"
          placeholder="Loading drift patterns markdown..."
        ><%= patternContent %></textarea>
        
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Commit Rules Save</button>
          <a class="btn btn-ghost" href="/">Cancel &amp; Abort</a>
        </div>
      </form>
      <p class="save-hint">
        * After committing changes, the evaluation page will automatically update with your new pattern definitions and signals.
      </p>
    </div>
  </section>

  <!-- Right Side: Rule Syntax Guidelines -->
  <aside class="help-card">
    <div class="help-title">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="margin-right: 4px; color: hsl(var(--accent)); vertical-align: middle;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Rule Grammar Guide
    </div>
    <p class="help-text">
      Drift patterns are parsed from standard Markdown headers and list segments. Use the syntax schema below to construct valid evaluators:
    </p>
    
    <div style="font-family: var(--font-mono); font-size: 0.8rem; background: hsl(var(--bg-primary)); border: 1px solid hsl(var(--border) / 0.5); padding: 1rem; border-radius: var(--radius-sm); color: hsl(var(--text-muted)); line-height: 1.5;">
      <span style="color: hsl(var(--accent)); font-weight: 700;">## Pattern: id_name</span><br>
      Status: active<br>
      Severity: high | medium | low<br>
      Requires no validation evidence: true | false<br>
      Title: Public Display Name<br>
      Assumption: Heuristic explanation...<br>
      Challenge: Intervention reflection prompt...<br><br>
      <span style="color: hsl(var(--accent)); font-weight: 700;">### Signals</span><br>
      - `/regex_1/flags`<br>
      - `/regex_2/flags`<br><br>
      <span style="color: hsl(var(--accent)); font-weight: 700;">### Examples</span><br>
      - Plain text example 1<br>
      - Plain text example 2
    </div>

    <div class="help-text" style="margin-top: 0.5rem;">
      <strong>Critical Constraints:</strong>
      <ul class="help-list" style="margin-top: 0.25rem;">
        <li>Keep regex expressions standard Javascript formats enclosed in forward slashes.</li>
        <li>Avoid destructive deletions of core patterns; instead, append new signals or tweak existing constraints to optimize performance.</li>
      </ul>
    </div>
  </aside>

</div>

<%- include('partials/footer') %>
